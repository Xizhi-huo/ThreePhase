{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Three-Phase React Tauri Demo",
  "version": "0.1.0",
  "identifier": "com.threephase.reacttauridemo",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Three-Phase UI Demo - React + Tauri",
        "width": 1180,
        "height": 760,
        "resizable": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
