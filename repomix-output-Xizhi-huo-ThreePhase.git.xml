                btn.setChecked(False)
                btn.setCursor(QtCore.Qt.ArrowCursor)
        else:
            for btn in self.tp_step_btns:
                btn.setCursor(QtCore.Qt.PointingHandCursor)
        for i in range(2, 7):
            try:
                self.tab_widget.setTabVisible(i, checked)
