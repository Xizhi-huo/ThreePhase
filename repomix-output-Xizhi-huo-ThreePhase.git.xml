class TestPanelMixin:
    """
    混入类，为 PowerSyncUI 提供合闸前测试模式的竖向控制条。
    """

    # ════════════════════════════════════════════════════════════════════
    # 构建入口
    # ════════════════════════════════════════════════════════════════════
    def _setup_test_panel(self):
        self._test_mode_active = False
        # dict: (step_key, gen_id) -> (brk_lbl, eng_btn_or_None, brk_btn, mode_rbs)
