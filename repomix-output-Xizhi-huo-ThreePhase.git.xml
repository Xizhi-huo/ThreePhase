        sg_lay = QtWidgets.QVBoxLayout(status_grp)

        self.loop_test_summary_lbl = QtWidgets.QLabel("")
        self.loop_test_summary_lbl.setStyleSheet("font-weight:bold; font-size:15px; color:#264653;")
